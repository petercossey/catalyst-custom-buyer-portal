# Required: BigCommerce WebDAV endpoint. Must end with /dav.
WEBDAV_URL=https://store-<store-hash>.mybigcommerce.com/dav

# Required: WebDAV credentials from Storefront WebDAV settings.
WEBDAV_USERNAME=<webdav-username>
WEBDAV_PASSWORD=<webdav-password>

# Optional: auto, password/basic, or digest. Leave as auto unless your store requires a specific auth mode.
WEBDAV_AUTH_TYPE=auto

# Optional: public content path inside WebDAV. The deploy script uploads releases under this directory.
WEBDAV_CONTENT_BASE_PATH=/content/b2b-buyer-portal-deployments

# Optional: fixed release folder name. Leave blank to auto-generate a timestamp + git SHA release name.
WEBDAV_RELEASE_NAME=

# Optional: app directory relative to the repo root.
STORE_APP_DIR=apps/storefront

# Optional: override the derived CDN URL if you want the script to print a specific public CDN base.
# BigCommerce CDN base format is typically:
# https://cdn11.bigcommerce.com/s-<store-hash>
# If omitted, the script derives the CDN URL automatically from WEBDAV_URL when possible.
WEBDAV_CDN_BASE_URL=https://cdn11.bigcommerce.com/s-<store-hash>/content/b2b-buyer-portal-deployments/<release-name>/
